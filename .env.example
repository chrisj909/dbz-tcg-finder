# Neon Database — copy connection string from console.neon.tech
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# Cron security — generate a random string and add it to Vercel env vars
# Vercel will send this in the Authorization header when invoking cron jobs
CRON_SECRET=your-random-secret-here

# Optional: Slack or Discord webhook URL for new-listing / price-drop alerts
ALERT_WEBHOOK_URL=

# Optional: eBay Browse API OAuth keys — register at https://developer.ebay.com
# (not required for the eBay source, which scrapes; only needed for #4)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional: TCGPlayer API keys
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=

# Neon Auth (powered by Better Auth) — gates the dashboard behind login.
# Enable in the Neon console: Project -> Branch -> Auth -> Configuration.
# NEON_AUTH_BASE_URL: copy the Auth Base URL shown there (looks like
#   https://ep-xxx.neonauth.<region>.aws.neon.tech/neondb/auth)
# NEON_AUTH_COOKIE_SECRET: generate locally, don't copy from the console:
#   openssl rand -base64 32
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
