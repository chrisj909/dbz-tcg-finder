# The scanner reads the repo-root .env.local by default:
#   node --env-file=.env.local scanner/run.js
#
# If you prefer a scanner-only env file, copy this to scanner/.env (gitignored)
# and run: node --env-file=scanner/.env scanner/run.js

# Neon connection (same value as the web app's DATABASE_URL)
DATABASE_URL=

# eBay Browse API (for the eBay source — #4). The legacy Finding API is dead.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
